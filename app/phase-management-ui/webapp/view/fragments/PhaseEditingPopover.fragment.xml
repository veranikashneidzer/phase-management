<core:FragmentDefinition
	xmlns="sap.m"
	xmlns:core="sap.ui.core">
	<Popover
		id="myPopover"
		title ="{oDetailConfigModel>/headerText}"
		class="sapUiResponsivePadding--header sapUiResponsivePadding--footer"
		placement="Bottom">
		<footer>
			<OverflowToolbar>
				<ToolbarSpacer/>
				<Button
                    text="{oDetailConfigModel>/buttonSubmitText}"
                    press=".onSubmitPhaseChanging"
                    />
                <Button
                    text="{i18n>dialogCancelButtonText}"
                    press=".onCancelPhaseChanging"
                    />
			</OverflowToolbar>
		</footer>
		<Image src="{ProductPicUrl}" width="15em" densityAware="false" />
	</Popover>
</core:FragmentDefinition>