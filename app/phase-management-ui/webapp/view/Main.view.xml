<mvc:View controllerName="phasemanagementui.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
	xmlns:core="sap.ui.core"
	xmlns:semantic="sap.f.semantic"
    xmlns="sap.m">
    <semantic:SemanticPage>
		<semantic:titleHeading>
			<Title text="{i18n>title}"/>
		</semantic:titleHeading>
		<semantic:content>
			<List
				id="contractsList"
				width="auto"
				items="{
					path: 'DataModel>/Contracts',
					parameters: {expand: 'Customer,Phases'},
					sorter: {
						path: 'DataModel>ID',
						descending: true
					}
				}">
				<headerToolbar>
					<OverflowToolbar>
						<SearchField
							showRefreshButton="true"
							tooltip="{i18n>search}"
							width="100%"
							search=".onSearchContracts">
							<layoutData>
								<OverflowToolbarLayoutData
									minWidth="150px"
									maxWidth="240px"
									shrinkable="true"
									priority="NeverOverflow"/>
							</layoutData>
						</SearchField>
						<ToolbarSpacer />
						<Button
							id="addButton"
							press=".onAddContract"
							icon="sap-icon://add"
							type="Transparent"/>
						<Button
							id="filterButton"
							press=".onOpenViewSettings"
							icon="sap-icon://filter"
							type="Transparent"/>
						<Button
							id="groupButton"
							press=".onOpenViewSettings"
							icon="sap-icon://group-2"
							type="Transparent"/>
					</OverflowToolbar>
				</headerToolbar>
				<items>
					<ObjectListItem
						title="{DataModel>description}"
						number="{DataModel>currency}"
						type="Navigation"
						key="{DataModel>ID}"
						press=".onSelectContract"
						core:require="{
							Formatter: 'phasemanagementui/model/formatter'
						}">
						<firstStatus>
								<ObjectStatus
									core:require="{
										Formatter: 'phasemanagementui/model/formatter'
									}"
									state="{
										path: 'DataModel>status',
										formatter:'Formatter.getStatusState'
									}"
									text="{DataModel>status}"/>

							</firstStatus>
							<attributes>
								<ObjectAttribute
									title="{i18n>startDate}"
									text="{
										path: 'DataModel>startDate',
										formatter: 'Formatter.formatDate'
									}" />
								<ObjectAttribute
									title="{i18n>endDate}"
									text="{
										path: 'DataModel>endDate',
										formatter: 'Formatter.formatDate'
									}" />
							</attributes>
					</ObjectListItem>
				</items>
			</List>
		</semantic:content>
    </semantic:SemanticPage>
</mvc:View>