<mvc:View
	controllerName="phasemanagementui.controller.Details"
	xmlns="sap.m"
	xmlns:f="sap.ui.layout.form"
	xmlns:core="sap.ui.core"
	xmlns:semantic="sap.f.semantic"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:l="sap.ui.layout">
	<semantic:SemanticPage
		id="detailPage"
		showFooter="{= ${oDetailConfigModel>/isEditMode} || ${oDetailConfigModel>/isContractCreation} }"
		core:require="{
			Formatter: 'phasemanagementui/model/formatter'
		}">
		<semantic:titleHeading>
			<Title
				text="{= ${oDetailConfigModel>/isContractCreation} ? ${i18n>addNewContract} : ${DataModel>description}}"/>
		</semantic:titleHeading>
		<semantic:headerContent>
			<l:HorizontalLayout id="headerContent">
				<l:VerticalLayout class="sapUiMediumMarginEnd">
					<Input
						value="{DataModel>description}" 
						id="descriptionControl"
						visible="{oDetailConfigModel>/isEditMode}" 
						required="true"
						valueStateText="{i18n>validationError}"
						liveChange=".onControlChanged"
						placeholder="{i18n>description}"/>
					<ObjectAttribute
						title="{i18n>startDate}"
						visible="{= !${oDetailConfigModel>/isEditMode}}"
						text="{
							path: 'DataModel>startDate',
							formatter: 'Formatter.formatDate'
						}" />
					<DatePicker
						placeholder="{i18n>startDate}" 
						id="startDateControl"
						visible="{oDetailConfigModel>/isEditMode}"
						displayFormat="dd-MM-yyyy" 
						valueFormat="yyyy-MM-dd" 
						value="{
							path: 'DataModel>startDate',
							formatter: 'Formatter.formatDate'
						}"
						valueStateText="{i18n>validationError}"
						liveChange=".onControlChanged"
						required="true" 
						/>
					<ObjectAttribute
						title="{i18n>endDate}"
						visible="{= !${oDetailConfigModel>/isEditMode}}"
						text="{
							path: 'DataModel>endDate',
							formatter: 'Formatter.formatDate'
						}" />
					<DatePicker
						placeholder="{i18n>endDate}" 
						id="endDateControl"
						visible="{oDetailConfigModel>/isEditMode}"
						displayFormat="dd-MM-yyyy" 
						valueFormat="yyyy-MM-dd" 
						value="{
							path: 'DataModel>endDate',
							formatter: 'Formatter.formatDate'
						}"
						valueStateText="{i18n>validationError}"
						liveChange=".onControlChanged"
						required="true" 
						/>
					<Label
						visible="{= !${oDetailConfigModel>/isEditMode}}"
						text="{= ${i18n>currency} + ': ' + ${DataModel>currency} }" />
					<ComboBox
						selectedKey="{DataModel>currency}"
						id="currencyControl"
						visible="{oDetailConfigModel>/isEditMode}"
					>
						<core:Item key="EUR" text="EUR" />
						<core:Item key="USD" text="USD" />
						<core:Item key="RUB" text="RUB" />
						<core:Item key="BYN" text="BYN" />
					</ComboBox>
					<Label
						visible="{= !${oDetailConfigModel>/isEditMode}}"
						id="status"
						text="{= ${i18n>status} + ': ' + ${DataModel>status} }" />
					<ComboBox
						selectedKey="{DataModel>status}"
						id="statusControl"
						visible="{oDetailConfigModel>/isEditMode}"
					>
						<core:Item key="Active" text="{i18n>active}" />
						<core:Item key="Inactive" text="{i18n>inactive}" />
						<core:Item key="Draft" text="{i18n>draft}" />
					</ComboBox>
				</l:VerticalLayout>
				<l:VerticalLayout>
					<Label
						visible="{= !${oDetailConfigModel>/isEditMode}}"
						text="{= ${i18n>customerName} + ': ' + ${DataModel>customer/name} }" />
					<Input
						value="{DataModel>customer/name}" 
						id="customerNameControl"
						visible="{oDetailConfigModel>/isEditMode}" 
						required="true"
						valueStateText="{i18n>validationError}"
						liveChange=".onControlChanged"
						placeholder="{i18n>customerName}"/>
					<Label
						visible="{= !${oDetailConfigModel>/isEditMode}}"
						text="{= ${i18n>customerAccountNumber} + ': ' + ${DataModel>customer/accountNumber} }" />
					<Input
						value="{DataModel>customer/accountNumber}" 
						id="customerAccountNumberControl"
						visible="{oDetailConfigModel>/isEditMode}" 
						required="true"
						valueStateText="{i18n>validationError}"
						liveChange=".onControlChanged"
						placeholder="{i18n>customerAccountNumber}"/>
				</l:VerticalLayout>
			</l:HorizontalLayout>
		</semantic:headerContent>
		<semantic:content>
			<Table
				id="phasesTable"
				items="{DataModel>phases}"
				mode="MultiSelect"
				growing="true"
				growingScrollToLoad="true">
				<headerToolbar>
					<OverflowToolbar id="otbSubheadeV4">
						<Title text="{i18n>phasesTableHeader}" level="H2" />
						<ToolbarSpacer/>
						<!-- <Button
							text="{i18n>buttonAdd}"
							class="sapUiTinyMarginEnd"
							press=".onAddPhaseToContract">
						</Button> -->
						<Button
							text="{i18n>buttonDelete}"
							class="sapUiTinyMarginEnd"
							enabled="{= !!${configModel>/isDeleteButtonEnabled}}"
							press=".onDeletePhaseFromContract">
						</Button>
						<!-- <Button
							text="{i18n>buttonEdit}"
							press=".onEditPhaseInContract">
						</Button> -->
					</OverflowToolbar>
				</headerToolbar>
				<columns>
					<Column>
						<Text text="{i18n>name}"/>
					</Column>
					<Column>
						<Text text="{i18n>startDate}"/>
					</Column>
					<Column>
						<Text text="{i18n>endDate}"/>
					</Column>
					<Column hAlign="End">
						<Text text="{i18n>monthlyPrice}"/>
					</Column>
					<Column>
						<Text text="{i18n>description}"/>
					</Column>
					<Column>
						<Text text="{i18n>totalPrice}"/>
					</Column>
				</columns>
				<items>
					<ColumnListItem>
						<cells>
						<Text
							text="{DataModel>name}"/>
						<Text
							text="{
								path: 'DataModel>startDate',
								formatter: 'Formatter.formatDate'
							}"/>
						<Text 
							text="{
								path: 'DataModel>endDate',
								formatter: 'Formatter.formatDate'
							}"/>
						<Text
							text="{DataModel>monthlyPrice}"/>
						<Text
							text="{DataModel>description}"/>
						<Text
							text="{
								parts: ['DataModel>startDate', 'DataModel>endDate', 'DataModel>monthlyPrice'],
								formatter: 'Formatter.calculateTotalPrice'
							}"/>
						</cells>
					</ColumnListItem>
				</items>
			</Table>
		</semantic:content>

		<semantic:deleteAction>
			<semantic:DeleteAction
				press=".onDeleteContract"/>
		</semantic:deleteAction>
		<semantic:editAction>
			<semantic:EditAction
				visible="{= !${oDetailConfigModel>/isEditMode}}"
				press=".onEditContract"/>
		</semantic:editAction>
		<semantic:closeAction>
			<semantic:CloseAction
				id="closeColumn"
				press=".onCloseContract"/>
		</semantic:closeAction>

		<semantic:footerCustomActions>
			<Button
				text="Save"
				press=".onSaveButtonPress"/>
			<Button
				text="Cancel"
				press=".onCancelEdit"/>
		</semantic:footerCustomActions>
	</semantic:SemanticPage>
</mvc:View>