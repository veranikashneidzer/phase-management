<mvc:View controllerName="phasemanagementui.controller.PhaseManagementUI"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">
    <Page id="page" title="{i18n>title}">
        <content>
            <Table
                id="customerTable"
                items="{ path: 'DataModel>/Contracts' }">

                <columns>
                    <Column>
                        <Text text="Description"/>
                    </Column>
                    <Column>
                        <Text text="Start date"/>
                    </Column>
                    <Column>
                        <Text text="End date"/>
                    </Column>
                    <Column>
                        <Text text="Currency"/>
                    </Column>
                    <Column>
                        <Text text="Status"/>
                    </Column>
                </columns>

                <items>
                    <ColumnListItem>
                        <cells>
                        <Text text="{DataModel>description}"/>
                        <Text text="{DataModel>startDate}"/>
                        <Text text="{DataModel>endDate}"/>
                        <Text text="{DataModel>currency}"/>
                        <Text text="{DataModel>status}"/>
                        </cells>
                    </ColumnListItem>
                </items>

            </Table>
        </content>
    </Page>
</mvc:View>